{
  "version": 8,
  "name": "Hakuna",
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    }
  },
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sprite": "mapbox://sprites/mapbox/light-v11",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#fdf9f0" }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["in", "class", "park", "cemetery", "pitch", "garden"],
      "paint": {
        "fill-color": "#f1ecd8",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": { "fill-color": "#ece8df" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#ddd7c8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 18, 3]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "composite",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#f1eee5",
        "fill-opacity": 0.85,
        "fill-outline-color": "#e6dfd4"
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "street", "street_limited", "service", "track", "pedestrian", "path"],
      "minzoom": 12,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#8f0041",
        "line-opacity": 0.18,
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 12, 0.5, 18, 9]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "street", "street_limited", "service", "track", "pedestrian", "path"],
      "minzoom": 12,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#d6316d",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 12, 0.3, 18, 6]
      }
    },
    {
      "id": "road-secondary-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "secondary", "tertiary", "primary", "link"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#8f0041",
        "line-opacity": 0.32,
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 8, 0.6, 18, 14]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "secondary", "tertiary", "primary", "link"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#b40f55",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 8, 0.4, 18, 10]
      }
    },
    {
      "id": "road-motorway-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "motorway", "trunk"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#8f0041",
        "line-opacity": 0.55,
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 5, 1, 18, 20]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", "class", "motorway", "trunk"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#ae2054",
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 5, 0.7, 18, 15]
      }
    },
    {
      "id": "admin-boundary",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["<=", "admin_level", 2],
      "paint": {
        "line-color": "#8c7075",
        "line-opacity": 0.3,
        "line-width": 0.8,
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": 11,
        "symbol-placement": "line",
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#594045",
        "text-halo-color": "#fdf9f0",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "place-label-suburb",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["in", "class", "suburb", "neighbourhood"],
      "minzoom": 11,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": 11,
        "text-letter-spacing": 0.15,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#8f0041",
        "text-opacity": 0.7,
        "text-halo-color": "#fdf9f0",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "place-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 11, 12, 18]
      },
      "paint": {
        "text-color": "#1c1c17",
        "text-halo-color": "#fdf9f0",
        "text-halo-width": 1.6
      }
    }
  ]
}
